# Azure DevOps — Personal Access Token
# Crie em: https://dev.azure.com/{sua-org}/_usersSettings/tokens
# Escopos mínimos: Work Items (Read & Write), Project and Team (Read)
AZDO_PAT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Organização (nome curto, não a URL completa)
AZDO_ORG=contoso

# URL da organização (opcional — usada para derivar AZDO_ORG se não informado)
AZDO_ORG_URL=https://dev.azure.com/contoso

# Projeto e time padrão
AZDO_PROJECT=Fabrikam
AZDO_TEAM=Fabrikam Team

# --- Documentos de evidência ---
# Destino principal (Drive local sincronizado: root/ano/quarter)
EVIDENCE_DRIVE_ROOT=G:/Drives compartilhados/Loyalty I/Evidências
# Fallback local se o Drive estiver somente leitura (padrão: .output/evidence)
# EVIDENCE_OUTPUT_ROOT=.output/evidence
EVIDENCE_TEMPLATE_PATH=templates/evidencia.template.docx
EVIDENCE_AMBIENTE_TESTE=UAT

# Override opcional de ano/quarter (padrão: calculado pela data atual)
# EVIDENCE_YEAR=2026
# EVIDENCE_QUARTER=Q2
