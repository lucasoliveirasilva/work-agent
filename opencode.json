{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ado-subtasks",
  "model": "openai/gpt-5.4",
  "mcp": {
    "azure-devops": {
      "type": "local",
      "command": [
        "node",
        "./node_modules/@azure-devops/mcp/dist/index.js",
        "contoso",
        "--authentication",
        "pat",
        "-d",
        "core",
        "work",
        "work-items"
      ],
      "enabled": true,
      "environment": {
        "ado_mcp_project": "Fabrikam",
        "ado_mcp_team": "Fabrikam Team"
      },
      "timeout": 120000
    }
  },
  "permission": {
    "edit": "deny",
    "bash": "deny",
    "write": "deny"
  }
}
