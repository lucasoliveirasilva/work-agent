{
  "name": "work-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Agente OpenCode para automação do fluxo de trabalho (Azure DevOps, evidências, etc.)",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File ./scripts/start.ps1",
    "test:mcp": "powershell -ExecutionPolicy Bypass -File ./scripts/test-mcp.ps1",
    "subtasks:list": "node scripts/subtasks/list-tasks.mjs",
    "subtasks:get": "node scripts/subtasks/get-task.mjs",
    "evidence:list": "node scripts/evidence/list-tasks.mjs",
    "evidence:generate": "node scripts/evidence/generate-doc.mjs",
    "triage:analyze": "node scripts/triage/analyze.mjs --save",
    "triage:apply": "node scripts/triage/apply.mjs"
  },
  "dependencies": {
    "@azure-devops/mcp": "^2.7.0",
    "docxtemplater": "^3.65.0",
    "pizzip": "^3.2.0"
  }
}
